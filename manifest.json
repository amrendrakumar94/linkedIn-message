{
  "manifest_version": 3,
  "name": "LinkedIn Message Copilot",
  "description": "Generate and copy a referral message from the extension side panel.",
  "version": "1.0.0",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "LinkedIn Message Copilot"
  },
  "permissions": ["storage", "sidePanel"],
  "side_panel": {
    "default_path": "popup.html"
  }
}
